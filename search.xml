    <title>sort</title>
    <url>/2020/04/02/sort/</url>
    <content><![CDATA[<pre><code class="cpp">void heapify(vector&lt;int&gt; &amp;tree, int len, int i){
    int cl = 2 * i + 1; //左节点
    int cr = 2 * i + 2; //右节点
    int max = i; //假设当前节点是最大值节点
    if (cl &lt; len &amp;&amp; tree[cl] &gt; tree[max]){
        max = cl; //最大值设为左节点
    }
    if (cr &lt; len &amp;&amp; tree[cr] &gt; tree[max]){
        max = cr; //最大值设为右节点
    }
    if (max != i){
        swap(tree[i], tree[max]); //交换元素
        heapify(tree, len, max); //对交换后的节点再进行堆化
    }

}//把当前第i个节点堆化

void build_heap(vector&lt;int&gt; &amp;tree){
    int len = tree.size();
    int parent = (len - 1) / 2;//最后一个叶节点的父节点
    for(int i = parent; i &gt;= 0; i--){
        heapify(tree, len, i);
    }
}//自下而上把树堆化

void heap_sort(vector&lt;int&gt; &amp;tree){
    int len = tree.size();
    build_heap(tree);
    for(int i = len - 1; i &gt;= 0; i--){
        swap(tree[i], tree[0]); //交换堆顶和最后一个节点的位置
        heapify(tree, i, 0); //重新堆化
    }
}</code></pre>
]]></content>
